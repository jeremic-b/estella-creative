---
// ============================================
// Footer — Site footer with year and logo
// ============================================
// Displays the current year dynamically and the Estella logo.
// The Logo component is shared with Navigation.
// ============================================

// Assets
import Logo from "@/components/assets/Logo.astro";

// Fundation components
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

// Current year for copyright display
const year = new Date().getFullYear();
---

<!-- Site footer -->
<footer>
  <Wrapper variant="standard" class="py-2">
    <div class="grid grid-cols-2 lg:grid-cols-4 items-start">
      <!-- Year + Logo -->
      <div
        class="flex items-center gap-2 text-base-600 dark:text-base-300 text-xs tracking-tight"
      >
        {year}
        <Logo />
      </div>
    </div>
  </Wrapper>
</footer>
